# 馃彺鬆仹鬆仮鬆伇鬆仯鬆伩 ReceiptTrac Environment Variables

# Required: OpenAI API Key (get at https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Google Cloud Vision credentials path (for backup OCR)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Flask Settings
SECRET_KEY=your-super-secret-key-change-this
FLASK_ENV=development
FLASK_PORT=5000

# Features (set to 'true' to enable)
ENABLE_TAX_CALC=true
ENABLE_EXPORT=true
